{
  "name": "strictplayer",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension that forces Space to always toggle play/pause on video players (YouTube, Twitch)",
  "scripts": {
    "build": "npm run build:popup && npm run build:content && npm run build:page",
    "build:popup": "vite build",
    "build:content": "vite build --config vite.content.config.ts",
    "build:page": "vite build --config vite.page.config.ts",
    "icons": "node scripts/generate-icons.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "sharp": "^0.35.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
